# ─── Application ─────────────────────────────────────────────────────────────
# Public app name shown in the UI
APP_NAME="DBStudio Dashboard"

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Base URL of your application (no trailing slash)
BASE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/next-starter"
DIRECT_URL=
# ─── Better Auth ──────────────────────────────────────────────────────────────
# Base URL used by Better Auth (should match BASE_URL)
BETTER_AUTH_URL="http://localhost:3000"

# Secret key used to sign sessions — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Sender email address (must be from a verified domain on Resend)
# For local development/testing only: use your own Resend account email
EMAIL_FROM="noreply@yourdomain.com"

# ─── Seed Configuration ───────────────────────────────────────────────────────
# Admin credentials for the first seed run.
# If SEED_ADMIN_PASSWORD is not set, a random password is generated and printed once.
SEED_ADMIN_EMAIL="admin@starter.com"
SEED_ADMIN_PASSWORD="changeme-before-production"

# ─── Session ──────────────────────────────────────────────────────────────────
# Session lifetime in seconds (default: 86400 = 24h)
SESSION_EXPIRY_SECONDS=86400
# How often session is refreshed in seconds (default: 3600 = 1h)
SESSION_UPDATE_AGE_SECONDS=3600